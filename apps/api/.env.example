# Openship API — Environment Variables
# Copy this file to .env and fill in the values.

NODE_ENV=development
PORT=4000

# ---------- Mode ----------
# Set to "true" to enable cloud billing, metering, multi-tenant features.
# Default: false (self-hosted single-tenant mode).
CLOUD_MODE=false

# ---------- Database ----------
DATABASE_URL=file:./dev.db

# ---------- Auth ----------
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- Stripe (Cloud mode only) ----------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ---------- GitHub App (for Git push webhooks) ----------
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=

OBLIEN_CLIENT_ID=oblien_403b39825cdcff9f2aac9a42c59f889692992a26309889f425149b33ecac6634
OBLIEN_CLIENT_SECRET=sk_e2abdcec6ee4e4885490079fa15178c05dd359474bfee6eb6998f55a3f1fddb8aea094191660ddb322dc144366e4bc80
