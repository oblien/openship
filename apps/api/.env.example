# Openship API — Environment Variables
# Copy this file to .env and fill in the values.

NODE_ENV=development
PORT=4000

# ---------- Mode ----------
# Set to "true" to enable cloud billing, metering, multi-tenant features.
# Default: false (self-hosted single-tenant mode).
CLOUD_MODE=false

# ---------- Openship Cloud ----------
# Local/self-hosted installs connect to the public cloud control plane.
OPENSHIP_CLOUD_URL=https://api.openship.io
OPENSHIP_CLOUD_DASHBOARD_URL=https://app.openship.io

# ---------- Database ----------
DATABASE_URL=file:./dev.db

# ---------- Auth ----------
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- Stripe (Cloud mode only) ----------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ---------- GitHub App (for Git push webhooks) ----------
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=

OBLIEN_CLIENT_ID=oblien_your-client-id
OBLIEN_CLIENT_SECRET=sk_your-client-secret
