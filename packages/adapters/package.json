{
  "name": "@repo/adapters",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@repo/core": "workspace:*",
    "dockerode": "^4.0.9",
    "oblien": "^2.1.8",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.13.0",
    "@types/ssh2": "^1.15.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
